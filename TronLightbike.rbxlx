      <Item class="ModuleScript" referent="5">
        <Properties>
          <string name="Name">Constants</string>
          <string name="Source"><![CDATA[return {
    BIKE_SPEED       = 60,
    BIKE_SIZE        = Vector3.new(2, 1, 4),
    TURN_ANGLE       = 90,
    GRID_SIZE        = 2,
    ARENA_SIZE       = 4096,
    TICK_RATE        = 30,
    TICK_INTERVAL    = 1 / 30,
    TRAIL_HEIGHT     = 3,
    TRAIL_WIDTH      = 0.5,
    TRAIL_FADE_TIME  = 10,
    TRAIL_MATERIAL   = Enum.Material.SmoothPlastic,
    BIKE_MATERIAL    = Enum.Material.SmoothPlastic,
    MAX_TURN_RATE    = 8,
    INTERP_DELAY     = 0.1,
    AI_SPEED         = 42,
    COLORS = {
        Color3.fromRGB(0, 255, 255),
        Color3.fromRGB(255, 128, 0),
        Color3.fromRGB(255, 0, 255),
        Color3.fromRGB(0, 255, 0),
    },
    DIRECTIONS = {
        EAST  = Vector3.new(1, 0, 0),
        WEST  = Vector3.new(-1, 0, 0),
        SOUTH = Vector3.new(0, 0, 1),
        NORTH = Vector3.new(0, 0, -1),
    },
    SPAWN_Y          = 1,
}
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="6">
        <Properties>
          <string name="Name">GameState</string>
          <string name="Source">local Constants = require(script.Parent.Constants)

local GameState = {}

function GameState.isHorizontal(seg)
    return seg.startZ == seg.endZ
end

function GameState.isVertical(seg)
    return seg.startX == seg.endX
end

function GameState.segmentsIntersect(segA, segB)
    local aHorizontal = GameState.isHorizontal(segA)
    local bHorizontal = GameState.isHorizontal(segB)

    if aHorizontal ~= bHorizontal then
        local hSeg, vSeg
        if aHorizontal then
            hSeg = segA
            vSeg = segB
        else
            hSeg = segB
            vSeg = segA
        end

        local hMinX = math.min(hSeg.startX, hSeg.endX)
        local hMaxX = math.max(hSeg.startX, hSeg.endX)
        local vMinZ = math.min(vSeg.startZ, vSeg.endZ)
        local vMaxZ = math.max(vSeg.startZ, vSeg.endZ)

        return vSeg.startX &gt;= hMinX and vSeg.startX &lt;= hMaxX
           and hSeg.startZ &gt;= vMinZ and hSeg.startZ &lt;= vMaxZ
    else
        if aHorizontal then
            if segA.startZ ~= segB.startZ then
                return false
            end
            local aMinX = math.min(segA.startX, segA.endX)
            local aMaxX = math.max(segA.startX, segA.endX)
            local bMinX = math.min(segB.startX, segB.endX)
            local bMaxX = math.max(segB.startX, segB.endX)
            return aMinX &lt;= bMaxX and bMinX &lt;= aMaxX
        else
            if segA.startX ~= segB.startX then
                return false
            end
            local aMinZ = math.min(segA.startZ, segA.endZ)
            local aMaxZ = math.max(segA.startZ, segA.endZ)
            local bMinZ = math.min(segB.startZ, segB.endZ)
            local bMaxZ = math.max(segB.startZ, segB.endZ)
            return aMinZ &lt;= bMaxZ and bMinZ &lt;= aMaxZ
        end
    end
end

function GameState.pointHitsSegment(x, z, seg)
    if GameState.isHorizontal(seg) then
        if z ~= seg.startZ then return false end
        local minX = math.min(seg.startX, seg.endX)
        local maxX = math.max(seg.startX, seg.endX)
        return x &gt;= minX and x &lt;= maxX
    else
        if x ~= seg.startX then return false end
        local minZ = math.min(seg.startZ, seg.endZ)
        local maxZ = math.max(seg.startZ, seg.endZ)
        return z &gt;= minZ and z &lt;= maxZ
    end
end

function GameState.isInsideArena(x, z)
    local half = Constants.ARENA_SIZE / 2
    return x &gt;= -half and x &lt;= half and z &gt;= -half and z &lt;= half
end

function GameState.makeSegment(startX, startZ, endX, endZ)
    return {
        startX = startX,
        startZ = startZ,
        endX = endX,
        endZ = endZ,
    }
end

function GameState.getActiveSegment(lastTurnPos, currentPos)
    return GameState.makeSegment(
        lastTurnPos.X, lastTurnPos.Z,
        currentPos.X, currentPos.Z
    )
end

return GameState</string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="7">
        <Properties>
          <string name="Name">Types</string>
          <string name="Source"><![CDATA[--[[
    Types.luau
    ==========
    Luau type definitions shared between client and server.
    These keep the data structures consistent across the network boundary.
]]

-- A single finalized trail segment stored as coordinate pairs.
-- Movement is axis-aligned, so each segment is either horizontal (X-axis) or vertical (Z-axis).
-- startY/endY are omitted because Y is constant (SPAWN_Y).
export type TrailSegment = {
    startX: number,
    startZ: number,
    endX: number,
    endZ: number,
}

-- Per-player state tracked on the server.
-- The server owns this table; clients receive snapshots of it.
export type PlayerState = {
    player: Player,
    bikePart: Part?,
    direction: Vector3,
    position: Vector3,
    lastTurnPosition: Vector3,
    lastTurnTime: number,
    trailHistory: { TrailSegment },
    alive: boolean,
    color: Color3,
    colorIndex: number,
}

-- A single player's data within a state snapshot, serialized for network transit.
-- Vector3s are broken into components to keep the payload small.
export type PlayerSnapshot = {
    userId: number,
    posX: number,
    posZ: number,
    dirX: number,
    dirZ: number,
    alive: boolean,
    colorIndex: number,
    trail: { TrailSegment },
}

-- The full game state snapshot broadcast to all clients every tick via UnreliableRemoteEvent.
export type GameStateSnapshot = {
    tick: number,
    players: { PlayerSnapshot },
}

-- Input buffer entry for queued turns (client-side grid snapping).
export type QueuedTurn = {
    newDirection: Vector3,
    timestamp: number,
}

return nil
]]></string>
        </Properties>
      </Item>
