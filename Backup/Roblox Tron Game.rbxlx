				<Item class="ModuleScript" referent="23">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StateUpdate = ReplicatedStorage:WaitForChild("StateUpdate")
local ReplicateTurn = ReplicatedStorage:WaitForChild("ReplicateTurn")

local Constants = require(ReplicatedStorage.Shared.Constants)

local EnemyInterpolation = {}

local enemyData = {}

function EnemyInterpolation.init()
    StateUpdate.OnClientEvent:Connect(function(snapshot)
        renderSnapshot(snapshot)
    end)

    ReplicateTurn.OnClientEvent:Connect(function(userId, segment)
        onReplicateTurn(userId, segment)
    end)

    print("[EnemyInterpolation] Initialized")
end

function ensureEnemyData(userId, colorIndex)
    local data = enemyData[userId]
    if data then return data end

    local bike = Instance.new("Part")
    bike.Anchored = true
    bike.CanCollide = false
    bike.Material = Constants.BIKE_MATERIAL
    bike.Color = Constants.COLORS[colorIndex] or Constants.COLORS[1]
    bike.Size = Constants.BIKE_SIZE
    bike.Parent = Workspace

    local activeTrail = Instance.new("Part")
    activeTrail.Anchored = true
    activeTrail.CanCollide = false
    activeTrail.Material = Constants.TRAIL_MATERIAL
    activeTrail.Color = Constants.COLORS[colorIndex] or Constants.COLORS[1]
    activeTrail.Parent = Workspace

    data = {
        bike = bike,
        trails = {},
        activeTrail = activeTrail,
    }
    enemyData[userId] = data
    return data
end

function destroyEnemyData(userId)
    local data = enemyData[userId]
    if not data then return end
    data.bike:Destroy()
    data.activeTrail:Destroy()
    for _, t in data.trails do
        t:Destroy()
    end
    enemyData[userId] = nil
end

function onReplicateTurn(userId, segment)
    if userId == Players.LocalPlayer.UserId then return end
    local data = enemyData[userId]
    if not data then return end

    local part = Instance.new("Part")
    part.Anchored = true
    part.CanCollide = false
    part.Material = Constants.TRAIL_MATERIAL
    part.Color = data.bike.Color
    part.Parent = Workspace

    local midX = (segment.startX + segment.endX) / 2
    local midZ = (segment.startZ + segment.endZ) / 2
    local dx = segment.endX - segment.startX
    local dz = segment.endZ - segment.startZ
    local length = math.max(math.abs(dx), math.abs(dz), Constants.TRAIL_WIDTH)
    part.Size = Vector3.new(Constants.TRAIL_WIDTH, Constants.TRAIL_HEIGHT, length)
    part.CFrame = CFrame.lookAt(
        Vector3.new(midX, Constants.TRAIL_HEIGHT / 2 - 0.5, midZ),
        Vector3.new(midX + dx, Constants.TRAIL_HEIGHT / 2 - 0.5, midZ + dz)
    )
    table.insert(data.trails, part)
end

function renderSnapshot(snapshot)
    for _, ps in snapshot.p do
        if ps.u == Players.LocalPlayer.UserId then
            continue
        end

        local data = ensureEnemyData(ps.u, ps.c)

        if not ps.a then
            data.bike:Destroy()
            data.activeTrail:Destroy()
            for _, t in data.trails do
                t:Destroy()
            end
            enemyData[ps.u] = nil
            continue
        end

        data.bike.Transparency = 0
        local pos = Vector3.new(ps.x, Constants.SPAWN_Y, ps.z)
        local dir = Vector3.new(ps.dx, 0, ps.dz)
        data.bike.CFrame = CFrame.lookAt(pos, pos + dir)

        data.activeTrail.Transparency = 0
        if ps.lx ~= nil and ps.lz ~= nil then
            local midX = (ps.lx + ps.x) / 2
            local midZ = (ps.lz + ps.z) / 2
            local dx = ps.x - ps.lx
            local dz = ps.z - ps.lz
            local length = math.max(math.abs(dx), math.abs(dz), Constants.TRAIL_WIDTH)
            data.activeTrail.Size = Vector3.new(Constants.TRAIL_WIDTH, Constants.TRAIL_HEIGHT, length)
            data.activeTrail.CFrame = CFrame.lookAt(
                Vector3.new(midX, Constants.TRAIL_HEIGHT / 2 - 0.5, midZ),
                Vector3.new(midX + dx, Constants.TRAIL_HEIGHT / 2 - 0.5, midZ + dz)
            )
        end
    end

    for userId, data in enemyData do
        local found = false
        for _, ps in snapshot.p do
            if ps.u == userId then
                found = true
                break
            end
        end
        if not found then
            destroyEnemyData(userId)
        end
    end
end

return EnemyInterpolation]]></ProtectedString>
						<string name="ScriptGuid">{14A5F95D-BF6B-4194-A810-100F390C5C02}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">EnemyInterpolation</string>
						<int64 name="SourceAssetId">-1</int64>
						<SharedString name="Tags">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
						<UniqueId name="UniqueId">2d0256b7391336c80a69beac0000253f</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="24">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[--[[
    LightbikeController.luau
    ========================
    Core client-side bike controller.
    - Replaces StarterCharacter with a Neon Part bike
    - Grid-snapped 90 degree movement with input buffering
    - Scriptable camera locked behind/above the bike
    - Fires TurnEvent to server on each turn
    - Drives LocalTrailRenderer each frame
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TurnEvent = ReplicatedStorage:WaitForChild("TurnEvent")
local DeathEvent = ReplicatedStorage:WaitForChild("DeathEvent")

local Constants = require(ReplicatedStorage.Shared.Constants)
local GameState = require(ReplicatedStorage.Shared.GameState)
local LocalTrailRenderer = require(script.Parent.LocalTrailRenderer)


local LightbikeController = {}

local bike: Part? = nil
local direction: Vector3 = Constants.DIRECTIONS.NORTH
local position: Vector3 = Vector3.new(0, Constants.SPAWN_Y, 0)
local lastTurnPosition: Vector3 = position
local alive: boolean = false
local inputBuffer: { Vector3 } = {}
local turnCooldown: number = 0
local cameraLerpSpeed: number = 8
local inputConnection: RBXScriptConnection? = nil
local renderConnection: RBXScriptConnection? = nil
local playerColor: Color3 = Constants.COLORS[1]

function LightbikeController.init()
    local player = Players.LocalPlayer
    if not player then
        player = Players.PlayerAdded:Wait()
    end

    player.CharacterAdded:Connect(function(char)
        task.wait(0.1)
        spawnBike(char)
    end)

    DeathEvent.OnClientEvent:Connect(function()
        LightbikeController.destroy()
    end)

    playerColor = Constants.COLORS[3]

    if player.Character then
        spawnBike(player.Character)
    end
end

function spawnBike(char: Model)
    if bike then
        bike:Destroy()
        bike = nil
    end
    if inputConnection then
        inputConnection:Disconnect()
        inputConnection = nil
    end
    if renderConnection then
        renderConnection:Disconnect()
        renderConnection = nil
    end
    alive = true
    direction = Constants.DIRECTIONS.NORTH
    position = Vector3.new(0, Constants.SPAWN_Y, 0)
    lastTurnPosition = position
    inputBuffer = {}
    turnCooldown = 0


    char:SetAttribute("TronBike", true)
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then
        for _, child in char:GetChildren() do
            if child:IsA("BasePart") then
                root = child
                break
            end
        end
    end
    if root then
        root.Anchored = true
        root.Transparency = 1
        root.CanCollide = false
    end
    for _, child in char:GetChildren() do
        if child:IsA("BasePart") and child ~= root then
            child.Transparency = 1
        end
    end

    bike = Instance.new("Part")
    bike.Name = "Lightbike"
    bike.Anchored = true
    bike.CanCollide = false
    bike.Material = Constants.BIKE_MATERIAL
    bike.Color = playerColor
    bike.Size = Constants.BIKE_SIZE
    bike.CFrame = CFrame.lookAt(position, position + direction)
    bike.Parent = Workspace

    LocalTrailRenderer.clear()
    LocalTrailRenderer.setColor(playerColor)
    LocalTrailRenderer.init(position, direction)

    local camera = Workspace.CurrentCamera
    camera.CameraType = Enum.CameraType.Scriptable
    local bikeCF = CFrame.lookAt(position, position + direction)
    local camOffset = bikeCF:VectorToWorldSpace(Vector3.new(0, 8, 16))
    camera.CFrame = CFrame.lookAt(position + camOffset, position + direction * 10 + Vector3.new(0, 2, 0))

    inputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed or not alive then return end
        if input.KeyCode == Enum.KeyCode.A then
            queueTurn(1)
        elseif input.KeyCode == Enum.KeyCode.D then
            queueTurn(-1)
        end
    end)

    renderConnection = RunService.RenderStepped:Connect(function(dt)
        if not alive or not bike then return end
        tickBike(dt)

        updateCamera(dt)
    end)
end

function queueTurn(sign: number)
    local newDir = CFrame.Angles(0, math.rad(sign * Constants.TURN_ANGLE), 0) * direction
    newDir = Vector3.new(math.round(newDir.X), 0, math.round(newDir.Z))
    table.insert(inputBuffer, newDir)
end

function tickBike(dt: number)
    turnCooldown = turnCooldown - dt

    local moveAmount = Constants.BIKE_SPEED * dt
    position = position + direction * moveAmount

    if #inputBuffer > 0 then
        if Constants.GRID_SIZE > 0 then
            local onCrossAxis = direction.X ~= 0 and position.Z or position.X
            local aligned = math.abs(math.round(onCrossAxis / Constants.GRID_SIZE) * Constants.GRID_SIZE - onCrossAxis) < moveAmount * 1.5
            if aligned then
                local newDir = inputBuffer[1]
                turnComplete(newDir)
                table.remove(inputBuffer, 1)
            end
        else
            local newDir = inputBuffer[1]
            turnComplete(newDir)
            table.remove(inputBuffer, 1)
        end
    end

    if turnCooldown <= 0 and #inputBuffer > 0 then
        if not positionSnapping() then
            turnComplete(inputBuffer[1])
            table.remove(inputBuffer, 1)
        end
    end

    bike.CFrame = CFrame.lookAt(position, position + direction)
    LocalTrailRenderer.update(position, lastTurnPosition)
end

function positionSnapping(): boolean
    if Constants.GRID_SIZE <= 0 then return false end
    if direction.X ~= 0 then
        local snapZ = math.round(position.Z / Constants.GRID_SIZE) * Constants.GRID_SIZE
        return math.abs(position.Z - snapZ) > 0.1
    else
        local snapX = math.round(position.X / Constants.GRID_SIZE) * Constants.GRID_SIZE
        return math.abs(position.X - snapX) > 0.1
    end
end

function turnComplete(newDir: Vector3)
    LocalTrailRenderer.finalizeSegment(lastTurnPosition, position)
    direction = newDir
    lastTurnPosition = position
    turnCooldown = 0.05
    TurnEvent:FireServer(lastTurnPosition, direction, os.clock())
end

function updateCamera(dt: number)
    local camera = Workspace.CurrentCamera
    local bikeCF = CFrame.lookAt(position, position + direction)
    local offset = bikeCF:VectorToWorldSpace(Vector3.new(0, 8, 16))
    local targetPos = position + offset
    local targetLook = position + direction * 10 + Vector3.new(0, 2, 0)
    local targetCF = CFrame.lookAt(targetPos, targetLook)
    local smoothFactor = 1 - math.exp(-cameraLerpSpeed * dt)
    camera.CFrame = targetCF
    camera.FieldOfView = 90 + (Constants.BIKE_SPEED / 10)
end

function LightbikeController.destroy()
    if bike then
        bike:Destroy()
        bike = nil
    end
    LocalTrailRenderer.clear()
    alive = false
end

return LightbikeController
]]></ProtectedString>
						<string name="ScriptGuid">{F835D359-BA54-45A2-9CBA-454AF813E6D9}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">LightbikeController</string>
						<int64 name="SourceAssetId">-1</int64>
						<SharedString name="Tags">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
						<UniqueId name="UniqueId">2d0256b7391336c80a69beac00002540</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="25">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Constants = require(ReplicatedStorage.Shared.Constants)

local LocalTrailRenderer = {}
local activePart = nil
local color = Constants.COLORS[1]

local function makePart()
    local p = Instance.new("Part")
    p.Anchored = true
    p.CanCollide = false
    p.Material = Constants.TRAIL_MATERIAL
    p.Color = color
    p.Parent = Workspace
    return p
end

function LocalTrailRenderer.init(initialPos: Vector3, initialDir: Vector3)
    if activePart then
        activePart:Destroy()
    end
    activePart = makePart()
    local endPos = initialPos + initialDir * Constants.TRAIL_WIDTH
    local mid = (initialPos + endPos) / 2
    mid = Vector3.new(mid.X, Constants.TRAIL_HEIGHT / 2 - 0.5, mid.Z)
    local dx = endPos.X - initialPos.X
    local dz = endPos.Z - initialPos.Z
    activePart.Size = Vector3.new(Constants.TRAIL_WIDTH, Constants.TRAIL_HEIGHT, Constants.TRAIL_WIDTH)
    activePart.CFrame = CFrame.lookAt(mid, mid + Vector3.new(dx, 0, dz))
end

function LocalTrailRenderer.update(currentPos: Vector3, lastTurnPos: Vector3)
    if not activePart then return end
    local startPos = lastTurnPos
    local endPos = currentPos
    local mid = (startPos + endPos) / 2
    mid = Vector3.new(mid.X, Constants.TRAIL_HEIGHT / 2 - 0.5, mid.Z)
    local dx = endPos.X - startPos.X
    local dz = endPos.Z - startPos.Z
    local length = math.max(math.abs(dx), math.abs(dz), Constants.TRAIL_WIDTH)
    activePart.Size = Vector3.new(Constants.TRAIL_WIDTH, Constants.TRAIL_HEIGHT, length)
    activePart.CFrame = CFrame.lookAt(mid, mid + Vector3.new(dx, 0, dz))
end

function LocalTrailRenderer.finalizeSegment(startPos: Vector3, endPos: Vector3)
    local mid = (startPos + endPos) / 2
    mid = Vector3.new(mid.X, Constants.TRAIL_HEIGHT / 2 - 0.5, mid.Z)
    local dx = endPos.X - startPos.X
    local dz = endPos.Z - startPos.Z
    local length = math.max(math.abs(dx), math.abs(dz), Constants.TRAIL_WIDTH)
    local seg = makePart()
    seg.Size = Vector3.new(Constants.TRAIL_WIDTH, Constants.TRAIL_HEIGHT, length)
    seg.CFrame = CFrame.lookAt(mid, mid + Vector3.new(dx, 0, dz))
end

function LocalTrailRenderer.setColor(c: Color3)
    color = c
    if activePart then
        activePart.Color = c
    end
end

function LocalTrailRenderer.clear()
    if activePart then
        activePart:Destroy()
        activePart = nil
    end
end

return LocalTrailRenderer
]]></ProtectedString>
