        <string name="Name">Server</string>
        <token name="RunContext">0</token>
        <string name="Source"><![CDATA[--[[
    init.server.luau
    ================
    Server bootstrapper. Requires and initializes all server modules.
    No game logic lives here - only the load order.
]]

local Constants = require(game.ReplicatedStorage.Shared.Constants)
local GameState = require(game.ReplicatedStorage.Shared.GameState)

local LightbikeServer = require(script.LightbikeServer)
local GameStateManager = require(script.GameStateManager)
local TrailManager = require(script.TrailManager)
local CollisionService = require(script.CollisionService)
local MatchManager = require(script.MatchManager)
local AIBot = require(script.AIBot)

print("[Server] Bootstrapping Tron Lightbike server modules...")
print("[Server] Constants loaded: BIKE_SPEED =", Constants.BIKE_SPEED, "| TICK_RATE =", Constants.TICK_RATE)
print("[Server] GameState helpers loaded: segmentsIntersect, pointHitsSegment, isInsideArena")

-- Initialize modules (stubs for now - they just print in Phase A)
TrailManager.init()
GameStateManager.init()
LightbikeServer.init()
CollisionService.init()
MatchManager.init()
AIBot.init()

print("[Server] All server modules initialized successfully.")
]]></string>
      </Properties>
      <Item class="ModuleScript" referent="12">
        <Properties>
          <string name="Name">AIBot</string>
          <string name="Source"><![CDATA[local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Constants = require(ReplicatedStorage.Shared.Constants)
local GameStateManager = require(script.Parent.GameStateManager)
local TrailManager = require(script.Parent.TrailManager)

local AIBot = {}

function AIBot.init()
    local fakePlayer = {
        UserId = 9999,
        Name = "AI_Bot",
    }

    local aiSpeed = Constants.AI_SPEED
    local colorIndex = 2
    local color = Constants.COLORS[colorIndex]
    local spawnPos = Vector3.new(-200, Constants.SPAWN_Y, -200)

    local bike = Instance.new("Part")
    bike.Name = "AIBot_Bike"
    bike.Anchored = true
    bike.CanCollide = false
    bike.Material = Constants.BIKE_MATERIAL
    bike.Color = color
    bike.Size = Constants.BIKE_SIZE
    bike.CFrame = CFrame.lookAt(spawnPos, spawnPos + Constants.DIRECTIONS.EAST)
    bike.Parent = Workspace

    local state = {
        player = fakePlayer,
        bikePart = bike,
        direction = Constants.DIRECTIONS.EAST,
        position = spawnPos,
        lastTurnPosition = spawnPos,
        lastTurnTime = os.clock(),
        trailHistory = {},
        alive = true,
        color = color,
        colorIndex = colorIndex,
        isAI = true,
    }

    local playerStates = GameStateManager.getPlayerStates()
    playerStates[fakePlayer] = state
    TrailManager.addPlayer(fakePlayer, color)

    local PATH = {
        { dir = Constants.DIRECTIONS.EAST,  dur = 3.0 },
        { dir = Constants.DIRECTIONS.SOUTH, dur = 3.0 },
        { dir = Constants.DIRECTIONS.WEST,  dur = 3.0 },
        { dir = Constants.DIRECTIONS.NORTH, dur = 3.0 },
    }
    local pathIdx = 1
    local pathTimer = 0
    local tickAcc = 0

    RunService.Heartbeat:Connect(function(dt)
        if not state.alive then return end

        tickAcc = tickAcc + dt
        while tickAcc >= Constants.TICK_INTERVAL do
            tickAcc = tickAcc - Constants.TICK_INTERVAL

            state.position = state.position + state.direction * aiSpeed * Constants.TICK_INTERVAL
            if state.bikePart then
                state.bikePart.CFrame = CFrame.lookAt(state.position, state.position + state.direction)
            end
            TrailManager.updateActiveSegment(fakePlayer, state.position, state.lastTurnPosition)

            pathTimer = pathTimer + Constants.TICK_INTERVAL
            local cur = PATH[pathIdx]
            if pathTimer >= cur.dur then
                pathTimer = 0
                pathIdx = pathIdx % #PATH + 1
                local next = PATH[pathIdx]
                GameStateManager.applyTurn(fakePlayer, state.position, next.dir)
            end
        end
    end)

    print("[AIBot] Initialized - spawned at", spawnPos, "speed", aiSpeed)
end

return AIBot
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="13">
        <Properties>
          <string name="Name">CollisionService</string>
          <string name="Source">local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Constants = require(ReplicatedStorage.Shared.Constants)
local GameStateHelpers = require(ReplicatedStorage.Shared.GameState)

local CollisionService = {}

function CollisionService.init()
    print("[CollisionService] Initialized")
end

function CollisionService.checkAll(playerStates)
    local dead = {}
    for player, state in pairs(playerStates) do
        if not state.alive then continue end
        if dead[player] then continue end

        if not GameStateHelpers.isInsideArena(state.position.X, state.position.Z) then
            dead[player] = true
        end

        local active = GameStateHelpers.getActiveSegment(state.lastTurnPosition, state.position)

        for i = 1, #state.trailHistory - 1 do
            if GameStateHelpers.segmentsIntersect(active, state.trailHistory[i]) then
                dead[player] = true
                break
            end
        end

        for otherPlayer, otherState in pairs(playerStates) do
            if otherPlayer == player then continue end

            for _, seg in pairs(otherState.trailHistory) do
                if GameStateHelpers.segmentsIntersect(active, seg) then
                    dead[player] = true
                    break
                end
            end

            if otherState.alive then
                local otherActive = GameStateHelpers.getActiveSegment(otherState.lastTurnPosition, otherState.position)
                if GameStateHelpers.segmentsIntersect(active, otherActive) then
                    dead[player] = true
                    dead[otherPlayer] = true
                end
            end
        end
    end
    return dead
end

return CollisionService</string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="14">
        <Properties>
          <string name="Name">GameStateManager</string>
          <string name="Source"><![CDATA[local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StateUpdate = ReplicatedStorage:WaitForChild("StateUpdate")
local ReplicateTurn = ReplicatedStorage:WaitForChild("ReplicateTurn")

local Constants = require(ReplicatedStorage.Shared.Constants)
local GameStateHelpers = require(ReplicatedStorage.Shared.GameState)
local TrailManager = require(script.Parent.TrailManager)
local CollisionService = require(script.Parent.CollisionService)
local MatchManager = require(script.Parent.MatchManager)

local GameStateManager = {}

local playerStates = {}
local tickAccumulator = 0
local tickNumber = 0

function GameStateManager.getPlayerStates()
    return playerStates
end

function GameStateManager.init()
    Players.PlayerAdded:Connect(function(player)
        createPlayerState(player)
    end)
    Players.PlayerRemoving:Connect(function(player)
        removePlayerState(player)
    end)
    for _, player in Players:GetPlayers() do
        createPlayerState(player)
    end

    RunService.Heartbeat:Connect(function(dt)
        tickAccumulator = tickAccumulator + dt
        while tickAccumulator >= Constants.TICK_INTERVAL do
            tickAccumulator = tickAccumulator - Constants.TICK_INTERVAL
            serverTick(Constants.TICK_INTERVAL)
        end
    end)

    print("[GameStateManager] Initialized")
end

function createPlayerState(player)
    local color = Constants.COLORS[(player.UserId - 1) % #Constants.COLORS + 1]
    local spawnPos = Vector3.new(0, Constants.SPAWN_Y, 0)

    local bike = Instance.new("Part")
    bike.Name = player.Name .. "Bike"
    bike.Anchored = true
    bike.CanCollide = false
    bike.Material = Constants.BIKE_MATERIAL
    bike.Color = color
    bike.Size = Constants.BIKE_SIZE
    bike.CFrame = CFrame.lookAt(spawnPos, spawnPos + Constants.DIRECTIONS.NORTH)
    bike.Parent = Workspace

    local state = {
        player = player,
        bikePart = bike,
        direction = Constants.DIRECTIONS.NORTH,
        position = spawnPos,
        lastTurnPosition = spawnPos,
        lastTurnTime = os.clock(),
        trailHistory = {},
        alive = true,
        color = color,
        colorIndex = (player.UserId - 1) % #Constants.COLORS + 1,
    }
    playerStates[player] = state
    TrailManager.addPlayer(player, color)
    print("[GameStateManager] Player added:", player.Name)
end

function removePlayerState(player)
    local state = playerStates[player]
    if state then
        if state.bikePart then
            state.bikePart:Destroy()
        end
        TrailManager.removePlayer(player)
        playerStates[player] = nil
        print("[GameStateManager] Player removed:", player.Name)
    end
end

function serverTick(dt)
    tickNumber = tickNumber + 1
    for _, state in playerStates do
        if state.alive and not state.isAI then
            state.position = state.position + state.direction * Constants.BIKE_SPEED * dt
            if state.bikePart then
                state.bikePart.CFrame = CFrame.lookAt(state.position, state.position + state.direction)
            end
            TrailManager.updateActiveSegment(state.player, state.position, state.lastTurnPosition)
        end
    end

    local dead = CollisionService.checkAll(playerStates)
    for player, _ in dead do
        local state = playerStates[player]
        if not state or not state.alive then continue end
        state.alive = false
        if state.bikePart then
            state.bikePart:Destroy()
            state.bikePart = nil
        end
        TrailManager.onDeath(player, state.position, state.lastTurnPosition)
        MatchManager.killBike(player)
    end
    broadcastState()
end

function broadcastState()
    local snapshot = { t = tickNumber, p = {} }
    for _, state in playerStates do
        local ps = {
            u = state.player.UserId,
            x = state.position.X,
            z = state.position.Z,
            dx = state.direction.X,
            dz = state.direction.Z,
            a = state.alive,
            c = state.colorIndex,
            lx = state.lastTurnPosition.X,
            lz = state.lastTurnPosition.Z,
        }
        snapshot.p[#snapshot.p + 1] = ps
    end
    StateUpdate:FireAllClients(snapshot)
end

function GameStateManager.applyTurn(player, turnPos, newDir)
    local state = playerStates[player]
    if not state or not state.alive then return end

    local seg = GameStateHelpers.makeSegment(
        state.lastTurnPosition.X, state.lastTurnPosition.Z,
        turnPos.X, turnPos.Z
    )
    table.insert(state.trailHistory, seg)
    ReplicateTurn:FireAllClients(player.UserId, seg)

    TrailManager.onTurn(player, turnPos, state.lastTurnPosition)
    state.lastTurnPosition = turnPos
    state.position = turnPos
    state.direction = newDir
    state.lastTurnTime = os.clock()
end

return GameStateManager
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="15">
        <Properties>
          <string name="Name">LightbikeServer</string>
          <string name="Source">--[[
    LightbikeServer.luau
    ====================
    Server-side turn validation and replication.
    - Listens for TurnEvent from clients
    - Ping compensation: validates turn distance is within speed * elapsed * 1.2
    - Rejects invalid turns (cheating, lag exploits)
    - Calls GameStateManager.applyTurn() for valid turns (which also fires ReplicateTurn)
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TurnEvent = ReplicatedStorage:WaitForChild("TurnEvent")

local Constants = require(ReplicatedStorage.Shared.Constants)
local GameStateManager = require(script.Parent.GameStateManager)

local LightbikeServer = {}

function LightbikeServer.init()
    TurnEvent.OnServerEvent:Connect(function(player, turnPos, newDir, timestamp)
        validateAndApplyTurn(player, turnPos, newDir, timestamp)
    end)
    print("[LightbikeServer] Initialized")
end

function validateAndApplyTurn(player, turnPos, newDir, timestamp)
    local states = GameStateManager.getPlayerStates()
    local state = states[player]
    if not state or not state.alive then return end

    local dot = state.direction.X * newDir.X + state.direction.Z * newDir.Z
    if math.abs(dot) &gt; 0.1 then
        return
    end

    if math.abs(newDir.X) + math.abs(newDir.Z) ~= 1 then
        return
    end

    local now = os.clock()
    local elapsed = now - state.lastTurnTime
    local maxDistance = Constants.BIKE_SPEED * math.max(elapsed, 0.016) * 1.2
    local actualDistance = (turnPos - state.lastTurnPosition).Magnitude
    if actualDistance &gt; maxDistance then
        return
    end

    GameStateManager.applyTurn(player, turnPos, newDir)
end

return LightbikeServer</string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="16">
        <Properties>
          <string name="Name">MatchManager</string>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DeathEvent = ReplicatedStorage:WaitForChild("DeathEvent")

local MatchManager = {}

function MatchManager.init()
    print("[MatchManager] Initialized")
end

function MatchManager.killBike(player)
    if typeof(player) == "Instance" then
        DeathEvent:FireClient(player)
    end
end

return MatchManager
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="17">
        <Properties>
          <string name="Name">TrailManager</string>
          <string name="Source"><![CDATA[local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Constants = require(ReplicatedStorage.Shared.Constants)

local TrailManager = {}

local trailData = {}

function TrailManager.init()
    print("[TrailManager] Initialized")
end

function TrailManager.addPlayer(player, color)
    trailData[player] = {
        segments = {},
        activePart = nil,
        lastLength = 0,
        color = color,
    }
end

function TrailManager.removePlayer(player)
    local data = trailData[player]
    if data then
        for _, part in data.segments do
            part:Destroy()
        end
        if data.activePart then
            data.activePart:Destroy()
        end
        trailData[player] = nil
    end
end

local function createSegmentPart(startPos, endPos, color)
    local mid = (startPos + endPos) / 2
    mid = Vector3.new(mid.X, Constants.TRAIL_HEIGHT / 2 - 0.5, mid.Z)
    local dx = endPos.X - startPos.X
    local dz = endPos.Z - startPos.Z
    local length = math.max(math.abs(dx), math.abs(dz), Constants.TRAIL_WIDTH)

    local seg = Instance.new("Part")
    seg.Anchored = true
    seg.CanCollide = false
    seg.Material = Constants.TRAIL_MATERIAL
    seg.Color = color
    seg.Size = Vector3.new(Constants.TRAIL_WIDTH, Constants.TRAIL_HEIGHT, length)
    seg.CFrame = CFrame.lookAt(mid, mid + Vector3.new(dx, 0, dz))
    seg.Parent = Workspace
    return seg
end

local function scheduleFade(seg, delay)
    task.delay(delay, function()
        if seg and seg.Parent then
            local tween = TweenService:Create(seg, TweenInfo.new(1), { Transparency = 1 })
            tween:Play()
            tween.Completed:Connect(function()
                seg:Destroy()
            end)
        end
    end)
end

function TrailManager.onTurn(player, turnPos, lastTurnPos)
    local data = trailData[player]
    if not data then return end

    if data.activePart then
        data.activePart:Destroy()
        data.activePart = nil
    end

    local seg = createSegmentPart(lastTurnPos, turnPos, data.color)
    table.insert(data.segments, seg)

    scheduleFade(seg, Constants.TRAIL_FADE_TIME)
end

function TrailManager.onDeath(player, deathPos, lastTurnPos)
    local data = trailData[player]
    if not data then return end

    if data.activePart then
        data.activePart:Destroy()
        data.activePart = nil
    end

    local seg = createSegmentPart(lastTurnPos, deathPos, data.color)
    table.insert(data.segments, seg)

    for _, seg in data.segments do
        scheduleFade(seg, 0)
    end
    data.segments = {}
end

function TrailManager.updateActiveSegment(player, currentPos, lastTurnPos)
    local data = trailData[player]
    if not data then return end

    if not data.activePart then
        data.activePart = Instance.new("Part")
        data.activePart.Anchored = true
        data.activePart.CanCollide = false
        data.activePart.Material = Constants.TRAIL_MATERIAL
        data.activePart.Color = data.color
        data.activePart.Parent = Workspace
    end

    local startPos = lastTurnPos
    local endPos = currentPos
    local mid = (startPos + endPos) / 2
    mid = Vector3.new(mid.X, Constants.TRAIL_HEIGHT / 2 - 0.5, mid.Z)
    local dx = endPos.X - startPos.X
    local dz = endPos.Z - startPos.Z
    local length = math.max(math.abs(dx), math.abs(dz), Constants.TRAIL_WIDTH)

    data.activePart.Size = Vector3.new(Constants.TRAIL_WIDTH, Constants.TRAIL_HEIGHT, length)
    data.activePart.CFrame = CFrame.lookAt(mid, mid + Vector3.new(dx, 0, dz))
end

return TrailManager
]]></string>
        </Properties>
      </Item>
